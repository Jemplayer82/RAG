# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# JWT
JWT_SECRET=CHANGE_ME_generate_64_random_chars

# Qdrant (Docker service name)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis (Docker service name)
REDIS_URL=redis://redis:6379/0

# LLM — defaults used when no admin config exists in the database
# Provider options: ollama | openai | anthropic | generic
LLM_PROVIDER=ollama
LLM_MODEL=mistral-small3.1
LLM_BASE_URL=http://host.docker.internal:11434
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# Legacy alias (still used by Ollama provider)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API Key Encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# Embeddings
EMBED_MODEL=BAAI/bge-large-en-v1.5
EMBED_DEVICE=cpu

# App
DEBUG=false
FLASK_SECRET_KEY=CHANGE_ME_generate_64_random_chars