# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password
# Automatically constructed in docker-compose — override only if self-hosting DB
# DATABASE_URL=postgresql://rag:changeme@postgres:5432/rag_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_64_random_chars

# ─── API Key Encryption ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_generate_fernet_key

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | generic
LLM_PROVIDER=ollama
LLM_MODEL=mistral-small3.1
LLM_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# Optional — only needed when using cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-large-en-v1.5
# Use "cuda" if a GPU is available
EMBED_DEVICE=cpu

# ─── Retrieval Tuning ─────────────────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=8
RERANK_TOP_K=5

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
