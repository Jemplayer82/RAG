# RAG System Configuration
# Copy this file to .env and adjust values as needed

# Data storage directory (default: ./data/ inside the project folder)
# RAG_DATA_DIR=C:/Users/Landon/OneDrive/Documents/Ai Projects/RAG/data

# Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434

# LLM model (must be pulled in Ollama: ollama pull mistral-small3.1)
LLM_MODEL=mistral-small3.1

# Embedding model (downloaded automatically from HuggingFace on first run)
EMBED_MODEL=BAAI/bge-large-en-v1.5
EMBED_DEVICE=cpu

# ChromaDB collection name
CHROMA_COLLECTION=rag_documents

# Chunking (tokens)
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# Retrieval
TOP_K=8
RERANK_TOP_K=5

# Flask
FLASK_SECRET_KEY=change_this_to_a_random_secret
DEBUG=false
